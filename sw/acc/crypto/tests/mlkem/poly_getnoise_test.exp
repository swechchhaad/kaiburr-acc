# Real poly_getnoise (init -> 256-byte squeeze -> f8) for seed=0^32, nonce in {0,1}.
# reference: f8(shake_256(0^32 || nonce)) with even/odd permutation, 16-bit lanes.
#   w10 = out0 word 0   (nonce 0, coeffs 0-15)
#   w11 = out0 word 1   (nonce 0, coeffs 16-31)
#   w12 = out0 word 15  (nonce 0, coeffs 240-255)
#   w13 = out1 word 0   (nonce 1, coeffs 0-15)
w10 = 0x00010d00000000000d0000010000000100010d000d000000000000000d000d00
w11 = 0x000100000d000000000100010d00000100010001000000000000000100000000
w12 = 0x0cff0d000000000100010d000d0000000001000000010d000d00000000000001
w13 = 0x0000000100000d0000000000000100000d0000010000000100010d0000010000
