name: "lowrisc:dv:acc_test:0.1"
description: "ACC DV UVM test"
filesets:
  files_dv:
    depend:
      - lowrisc:dv:acc_env
      - lowrisc:dv:acc_memutil
    files:
      - acc_test_pkg.sv
      - acc_base_test.sv: {is_include_file: true}
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_dv
