{
  /**
   * @param[out] dmem[d0]: First share of secret key.
   * @param[out] dmem[d1]: Second share of secret key.
   * @param[out]  dmem[x]: Public key x-coordinate.
   * @param[out]  dmem[y]: Public key y-coordinate.
   */

  "input": {
    "dmem": {
      "mode": "0x000001f8"  # MODE_KEYGEN
    }
  }
  "output": {
    "dmem": {
      # Verified that (x, y) == (d0 + d1) * G
      "x": "0x9fad5e132795f8f6ad132dd45eba5c5c706e053208a09a48ad47c7b35491f817"
      "y": "0x124bcfa822f7220150a57978762692fbaace3e8491290a8496da05f87462f476"

      "d0":
        '''
          0x000000000000000000000000000000000000000000000000402471bc95de7bd
          1981bd5ca3c71b2ee9ebf678bfaf301178e4dd0c25b2a8dcf890a2469e1e4dab4
        '''

      "d1":
        '''
          0x0000000000000000000000000000000000000000000000009d52ac9b72e9888
          129ff7b160429747e1ef21f96cd0dbcd12d797be576d48d504d9ce98a2b510e87
        '''
    }
  }
}
