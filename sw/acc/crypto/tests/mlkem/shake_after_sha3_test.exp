w4 = 0x333279e7c3c27db00946a986ba50728d11269a0734885e216a18c0e6840ab225
w5 = 0x7c47f84ead2416c4836d6bb7d58f133ae17c7e4cb4068719c4178fea523c9c7b
w7 = 0xffe4dea5e1ec20211c45c2a69699839a58e8b1dc7ac8be34f04115f9530a7480
